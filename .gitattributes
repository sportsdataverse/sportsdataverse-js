# Auto detect text files and perform LF normalization
* text=auto

# Source + config are always checked out as LF (overriding core.autocrlf on
# Windows) so the codegen drift gate (`npm run codegen:check`) is deterministic
# across platforms — the generator in tools/codegen always emits LF.
*.ts   text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Generated docs reference is emitted with LF by tools/codegen/generate.mjs; pin
# it to LF so `npm run codegen:check` is deterministic on Windows — WITHOUT
# forcing every hand-written .md (intro, tutorials) to LF.
docs/docs/reference/*.md   text eol=lf
docs/src/playground/*.json text eol=lf
