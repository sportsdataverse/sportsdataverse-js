# Auto detect text files and perform LF normalization
* text=auto

# Source + config are always checked out as LF (overriding core.autocrlf on
# Windows) so the codegen drift gate (`npm run codegen:check`) is deterministic
# across platforms — the generator in tools/codegen always emits LF.
*.ts   text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Docs are emitted/edited with LF by tools/codegen (the reference + per-league
# written-source dirs), tools/docs (the output injector, which rewrites guide
# .mdx), and the playground metadata. Pin the whole docs/docs tree + the
# generated dirs to LF so `npm run codegen:check` / `docs:examples:check` are
# deterministic on Windows (core.autocrlf was the recurring false "drift").
docs/docs/**               text eol=lf
docs/src/generated/**      text eol=lf
docs/src/playground/*.json text eol=lf
docs/src/playground/*.mjs  text eol=lf
