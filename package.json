{
  "name": "sportsdataverse",
  "version": "2.2.0",
  "type": "module",
  "description": "Node.js client which retrieves sports data from the ESPN API as well as from the NCAA website, with support for NBA, NFL, NHL, MLB, WNBA, men's and women's college basketball, and college football.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "directories": {
    "test": "test"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "decode-html": "^2.0.0",
    "tabletojson": "^4.1.10"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "mocha": "^11.7.6",
    "should": "^13.2.3",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "mocha --timeout 15000 \"test/**/*.test.js\"",
    "docs": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sportsdataverse/sportsdataverse-js.git"
  },
  "keywords": [
    "sports",
    "nba",
    "nfl",
    "nhl",
    "mlb",
    "wnba",
    "cbb",
    "wbb",
    "ncaa",
    "espn",
    "basketball",
    "hoops",
    "college-basketball",
    "water-polo-men",
    "water-polo-women",
    "men's-water-polo",
    "women's-water-polo",
    "basketball",
    "ncaa-w",
    "basketball-men",
    "basketball-women",
    "mens-basketball",
    "women's-basketball",
    "men's-soccer",
    "women's-soccer",
    "soccer-men",
    "soccer-women",
    "mens-ice-hockey",
    "women's-ice-hockey",
    "field-hockey",
    "men's-ice-hockey",
    "women's-ice-hockey",
    "ice-hockey-men",
    "ice-hockey-women",
    "baseball",
    "softball",
    "men's-volleyball",
    "women's-volleyball",
    "volleyball-men",
    "volleyball-women",
    "beach-volleyball",
    "women's-beach-volleyball",
    "men's-lacrosse",
    "women's-lacrosse",
    "lacrosse-men",
    "lacrosse-women",
    "men's-tennis",
    "women's-tennis",
    "tennis-men",
    "tennis-women",
    "women's-bowling",
    "bowling-women",
    "statistics",
    "football",
